# --- Repository Branch Configuration ---
# Uncomment and set these variables in your .env file to override the default branches
# used by the setup-repos.sh script. If left commented or unset, the script defaults will be used.

BLOCK_BUILDER_BRANCH=main
EXECUTION_LAYER_BRANCH=main
KASWALLET_BRANCH=main
IGRA_RPC_PROVIDER_BRANCH=main
VIADUCT_BRANCH=main

# The following branches are only used if you run ./setup-repos.sh --dev
KASPAD_BRANCH=master
KASPA_MINER_BRANCH=main

# IGRA Network:
NETWORK=testnet

# HTTPS domain settings
IGRA_ORCHESTRA_DOMAIN=stage.igralabs.com
IGRA_ORCHESTRA_DOMAIN_EMAIL=igor@igralabs.com

# --- Docker Configuration ---

# Logging driver for Docker containers.
# Defaults to 'syslog' which works well on Linux.
# On macOS, 'json-file' is recommended as 'syslog' might not be available or work correctly.
LOGGING_DRIVER=json-file

# General and share configuration
RUST_LOG=debug
IGRA_CHAIN_ID=19416
IGRA_LAUNCH_DAA_SCORE=26927000
L1_REFERENCE_TIMESTAMP=1752450516
L1_REFERENCE_DAA_SCORE=200184247
MIN_PROTOCOL_FEE_PER_GAS_GWEI=2000
GENESIS_BLOCK_HASH=0x479dddc40e7b1548f93b71a51f54565c5eccabaf7c70ac96125b98d4ca587e8d

# Kaspad configuration
KASPAD_HOST=kaspad
KASPAD_BORSH_PORT=17610
KASPAD_ADD_PEER=<ip-address> # optional argument

# Viaduct configuration
REPLAY_ON_ERROR=-1
SYNC_THREADS=64
MAGIC_SPK=20587b999b5b38f5c87ce04e4a2100998a05d303cc54c30ec77fa2c51dc5aa0a53ac
DELAY_BLOCKS=0

# Mining configuration
MINING_ADDRESS=kaspadev:qqdk7fjp3dk6yln3d8epz6exafv65jecxkz9ujkhlvgkqwefwtdwsw3q78u7s
MINING_THREADS=1

# Execution Layer:
EL_ONE_TIME_ADDRESS=0x2B7dABDF193677725C6Ecd25dc7CfAf6054193d8


# RPC Access Tokens (ensure that they are 32 hexadecimal characters)
RPC_ACCESS_TOKEN_1=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
RPC_ACCESS_TOKEN_2=bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
RPC_ACCESS_TOKEN_3=cccccccccccccccccccccccccccccccc
RPC_ACCESS_TOKEN_4=dddddddddddddddddddddddddddddddd
RPC_ACCESS_TOKEN_5=eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee
RPC_ACCESS_TOKEN_6=ffffffffffffffffffffffffffffffff
