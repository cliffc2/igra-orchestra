# --- S3 Backup Configuration (Optional) ---
# Configure these settings to enable automatic backup uploads to AWS S3
# AWS credentials should be configured via AWS CLI or IAM roles, not in this file

# S3 bucket name for storing backups
S3_BACKUP_BUCKET=igralabs-viaduct-archival-data

# AWS region where the S3 bucket is located
S3_BACKUP_REGION=eu-north-1

# Number of backups to retain in S3 (older backups will be automatically deleted)
S3_BACKUP_RETENTION_COUNT=10

# Enable dry-run mode for testing (no actual S3 operations will be performed)
S3_BACKUP_DRY_RUN=false

# Automatically upload backups to S3 after local backup completes
S3_BACKUP_AUTO_UPLOAD=false

# S3 storage class for cost optimization (STANDARD, STANDARD_IA, GLACIER, etc.)
S3_BACKUP_STORAGE_CLASS=STANDARD_IA

# --- Cron Backup Configuration (Optional) ---
# Containers to backup via cron (space-separated list)
CRON_BACKUP_CONTAINERS="viaduct"

# AWS profile to use for cron S3 uploads (if different from default)
AWS_PROFILE=igra-labs