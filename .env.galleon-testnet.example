# Galleon Public Testnet Services Configuration
# Configuration for running IGRA Orchestra on Kaspa testnet with pre-built images

# --- Docker Configuration ---
# Set to true to use pre-built Docker Hub images for testnet deployment
# Set to false to build from source code (requires access to private repositories)
USE_PREBUILT_IMAGES=true

# Logging driver for Docker containers
# On Linux: 'syslog' works well
# On macOS: 'json-file' is recommended
LOGGING_DRIVER=json-file

# --- IGRA Network Configuration ---
NETWORK=testnet

# IGRA Enable/Disable
# Set to false for initial kaspad sync without IGRA overhead, then set to true and restart
IGRA_ENABLE=true

# --- Galleon Testnet Chain Configuration ---
IGRA_CHAIN_ID=38836
IGRA_LAUNCH_DAA_SCORE=368045400
GENESIS_BLOCK_HASH=0xcde7665949ac157e4d4ee866141ef20d991e5ce1fe6ffc20b874198f9dd2e9d8
TX_ID_PREFIX=97b4
L1_REFERENCE_TIMESTAMP=1768475045
L1_REFERENCE_DAA_SCORE=361004030
MIN_PROTOCOL_FEE_PER_GAS_GWEI=2000
IGRA_ENTRY_MIN_AMOUNT=100000000

# Lock script address: kaspatest:qpv5yg3hthdf3ag09gjdyl2qeu3z73s60uzl5zrrgc3kwa840lxvg6a57kr2r
IGRA_LOCK_SCRIPT_PUBKEY=203705fd429b0ab82518dc8b0bef2756c87d797d08bc16f2a25b9b3d4365ad1529ac

# Execution Layer one-time address
EL_ONE_TIME_ADDRESS=0xDD2472750F8273F31fDC4D39FAFc83e3467d9eDD

# --- Logging Configuration ---
RUST_LOG=info
ENABLE_PERF_DIAGNOSTICS=false
ENABLE_EVENT_LOGGING=false

# --- ATAN Import Configuration ---
# CDN base URL for ATAN data (required for kaspad and atan-uploader services)
CDN_BASE_URL=https://dyehoijgeqfp8.cloudfront.net
# ATAN auto-import URL is auto-constructed: {CDN_BASE_URL}/{NETWORK}/{TX_ID_PREFIX}/index.pb

# --- Kaspad Configuration ---
KASPAD_HOST=kaspad
KASPAD_GRPC_PORT=16210
KASPAD_P2P_PORT=16211
KASPAD_BORSH_PORT=17210
KASPAD_JSON_PORT=18210

# Peer to connect to for initial sync (Galleon testnet bootstrap node)
KASPAD_ADD_PEER=65.109.78.124

# --- RPC Configuration ---
# Set to true for read-only RPC (no transaction submission)
# Set to false if you want to accept and submit user transactions (requires funded wallets)
RPC_READ_ONLY=true

# --- Node Settings ---
NODE_ID=GTN-<your-unique-node-name>

# Shared testnet monitoring API key (public for Galleon testnet)
HEALTH_CHECK_API_KEY=13ceaacb3c9aa716d1d3545282951f76a8cc1a23bc10862d67bb2a5b856a1994

# Node health check monitoring server (required for health reporting)
NODE_HEALTH_CHECK_URL=galleon-testnet.igralabs.com

# --- HTTPS Domain Settings ---
IGRA_ORCHESTRA_DOMAIN=<your-domain.com>
IGRA_ORCHESTRA_DOMAIN_EMAIL=<you@your-domain.com>

# --- Core Contracts Configuration (Optional) ---
# Set to true only if you need to deploy or modify IGRA core contracts
# This repository is not available as a pre-built image and will be cloned from source
CLONE_CORE_CONTRACTS=false
CORE_CONTRACTS_BRANCH=main

# --- Worker Configuration ---
# All wallet addresses must use testnet prefix: kaspatest:
# Generate keys for testnet:
#   docker run --rm -it -v $(pwd)/keys:/keys --entrypoint /app/kaswallet-create \
#     igranetwork/kaswallet:2.0.1 --testnet -k /keys/keys.kaswallet-X.json

# IMPORTANT: Each worker MUST have a unique address after key generation!
# The addresses below are placeholders and will NOT work - replace them!
# See "Optional: Enable RPC Transaction Submission" section in documentation

# Worker 0
W0_WALLET_TO_ADDRESS=kaspatest:qpvud9rdcqnqydqqfz2xunkh69xv5pflfacpjvrdgvdfven8yu2fcknegxade
W0_KASWALLET_PASSWORD=<your-password>

# Worker 1
W1_WALLET_TO_ADDRESS=kaspatest:qpvud9rdcqnqydqqfz2xunkh69xv5pflfacpjvrdgvdfven8yu2fcknegxade
W1_KASWALLET_PASSWORD=<your-password>

# Worker 2
W2_WALLET_TO_ADDRESS=kaspatest:qpvud9rdcqnqydqqfz2xunkh69xv5pflfacpjvrdgvdfven8yu2fcknegxade
W2_KASWALLET_PASSWORD=<your-password>

# Worker 3
W3_WALLET_TO_ADDRESS=kaspatest:qpvud9rdcqnqydqqfz2xunkh69xv5pflfacpjvrdgvdfven8yu2fcknegxade
W3_KASWALLET_PASSWORD=<your-password>

# Worker 4
W4_WALLET_TO_ADDRESS=kaspatest:qpvud9rdcqnqydqqfz2xunkh69xv5pflfacpjvrdgvdfven8yu2fcknegxade
W4_KASWALLET_PASSWORD=<your-password>
