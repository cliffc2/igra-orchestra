# Mainnet Services Configuration
# Configuration for running IGRA Orchestra on Kaspa mainnet with pre-built images

# --- Docker Configuration ---
# Set to true to use pre-built Docker Hub images for mainnet deployment
USE_PREBUILT_IMAGES=true

# --- IGRA Network Configuration ---
NETWORK=mainnet

# IGRA Enable/Disable
# Set to false for initial kaspad sync without IGRA overhead, then set to true and restart
IGRA_ENABLE=true

# --- General and Shared Configuration ---
# IMPORTANT: These values are mainnet-specific - obtain from IGRA team
RUST_LOG=info
IGRA_CHAIN_ID=<MAINNET_CHAIN_ID>
IGRA_LAUNCH_DAA_SCORE=<MAINNET_LAUNCH_DAA_SCORE>
GENESIS_BLOCK_HASH=<MAINNET_GENESIS_BLOCK_HASH>
EL_ONE_TIME_ADDRESS=<MAINNET_EL_ONE_TIME_ADDRESS>
L1_REFERENCE_TIMESTAMP=<MAINNET_L1_REFERENCE_TIMESTAMP>
L1_REFERENCE_DAA_SCORE=<MAINNET_L1_REFERENCE_DAA_SCORE>
MIN_PROTOCOL_FEE_PER_GAS_GWEI=2000
IGRA_ENTRY_MIN_AMOUNT=100000000
IGRA_LOCK_SCRIPT_PUBKEY=<MAINNET_IGRA_LOCK_SCRIPT_PUBKEY>
ENABLE_PERF_DIAGNOSTICS=false
ENABLE_EVENT_LOGGING=false


# Transaction ID prefix for ATAN (hex-encoded, even number of chars)
# IMPORTANT: Mainnet uses a different TX_ID_PREFIX than testnet
TX_ID_PREFIX=<MAINNET_TX_PREFIX>

# --- ATAN Import Configuration ---
# CDN base URL for ATAN data (required for kaspad and atan-uploader services)
CDN_BASE_URL=https://dyehoijgeqfp8.cloudfront.net
# ATAN auto-import URL for importing ATAN data on kaspad startup (remote URLs only)
# Auto-constructed from CDN_BASE_URL, NETWORK and TX_ID_PREFIX: {CDN_BASE_URL}/{NETWORK}/{TX_ID_PREFIX}/index.pb
# Override only if you need a custom remote URL
# ATAN_IMPORT_URL=

# --- ATAN Uploader (S3 uploader + indexer) ---
# Uploads new ATAN chain block list files to S3 and maintains an index.pb
# Uses NETWORK variable (defined above) to determine correct data paths
# Uses TX_ID_PREFIX variable (defined above) for transaction filtering
#
# Required:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# DATADIR path must match the network (NETWORK variable above):
#   testnet: /app/data/kaspa-testnet-10/datadir
#   mainnet: /app/data/kaspa-mainnet/datadir
DATADIR=/app/data/kaspa-mainnet/datadir
#
# Optional (defaults shown below are from docker-compose.yml):
# AWS_REGION=us-east-1
# S3_BUCKET=atan-import

# --- Kaspad Configuration ---
KASPAD_HOST=kaspad
# Mainnet ports (different from testnet: 16210, 16211, 17210, 18210)
KASPAD_GRPC_PORT=16110
KASPAD_P2P_PORT=16111
KASPAD_BORSH_PORT=17110
KASPAD_JSON_PORT=18110

# --- RPC Configuration ---
RPC_READ_ONLY=false

# --- Node Settings ---
NODE_ID=<your-node-name>
HEALTH_CHECK_API_KEY=<your-api-key>

# --- HTTPS Domain Settings ---
IGRA_ORCHESTRA_DOMAIN=<your-domain.com>
IGRA_ORCHESTRA_DOMAIN_EMAIL=<you@your-domain.com>

# --- Worker Configuration ---
# All wallet addresses must use mainnet prefix: kaspa:
# Generate keys with --enable-mainnet-pre-launch flag:
#   docker run --rm -it -v $(pwd)/keys:/keys --entrypoint /app/kaswallet-create \
#     igranetwork/kaswallet:latest --enable-mainnet-pre-launch -k /keys/keys.kaswallet-X.json

# Worker 0
W0_WALLET_TO_ADDRESS=kaspa:<your-mainnet-address-0>
W0_KASWALLET_PASSWORD=<your-password-0>

# Worker 1
W1_WALLET_TO_ADDRESS=kaspa:<your-mainnet-address-1>
W1_KASWALLET_PASSWORD=<your-password-1>

# Worker 2
W2_WALLET_TO_ADDRESS=kaspa:<your-mainnet-address-2>
W2_KASWALLET_PASSWORD=<your-password-2>

# Worker 3
W3_WALLET_TO_ADDRESS=kaspa:<your-mainnet-address-3>
W3_KASWALLET_PASSWORD=<your-password-3>

# Worker 4
W4_WALLET_TO_ADDRESS=kaspa:<your-mainnet-address-4>
W4_KASWALLET_PASSWORD=<your-password-4>

